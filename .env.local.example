# ──────────────────────────────────────────────
# 수행Lab 환경변수 예시 — 실제 값은 .env.local에 넣으세요 (절대 git에 올리지 않음)
# ──────────────────────────────────────────────

# 1) Google OAuth 2.0 Client — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 2) 앱이 배포된 URL (OAuth redirect_uri에 사용됨)
#    로컬 개발: http://localhost:3000
#    프로덕션: https://your-domain.vercel.app
APP_URL=http://localhost:3000

# 3) 세션 쿠키 암호화용 시크릿 (32자 이상 무작위 문자열)
#    생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# 4) Vercel KV 연결 정보 (Vercel Dashboard → Storage에서 발급받은 값)
#    로컬 개발 시 `vercel env pull`로 자동 주입 가능
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
